# ── 資料庫（Zeabur PostgreSQL 服務會自動注入 DATABASE_URL）──
DATABASE_URL=postgresql://user:password@host:5432/dbname
# 若資料庫需要 SSL，設為 require
PGSSL=disable

# ── 安全 ──
# JWT 簽章密鑰：請換成一長串亂數（例如 openssl rand -hex 32）
JWT_SECRET=change-me-to-a-long-random-string

# ── 管理者帳號（首次啟動自動建立；建立後請立即登入改密碼）──
ADMIN_EMAIL=neowu62@gmail.com
ADMIN_PASSWORD=change-me-on-first-login

# ── 前端 ──
# 允許呼叫本 API 的前端網址（多個用逗號分隔）
ALLOWED_ORIGIN=https://nbpmclaude.zeabur.app
# 前端網址（產生 email 驗證/重設連結用）
PUBLIC_SITE_URL=https://nbpmclaude.zeabur.app

# ── 寄信服務 ──
# 方式一（採用）：Gmail SMTP + 應用程式密碼（16 碼，含不含空格皆可）
GMAIL_USER=neowu62@gmail.com
GMAIL_APP_PASSWORD=在此填入你的應用程式密碼
MAIL_FROM=Claude PM 手冊 <neowu62@gmail.com>
# 方式二（備援，可留空）：Resend
RESEND_API_KEY=

NODE_ENV=production
PORT=8080
